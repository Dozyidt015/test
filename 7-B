#include <iostream>
#include <iomanip>

using namespace std;

// Function prototypes
double getFahrenheit();
double calcCelsius(double fahrenheit);

int main() {
    double fahr;
    int cels;

    // 1. Call getFahrenheit function to get the Fahrenheit temperature
    fahr = getFahrenheit();

    // 2. Call the calcCelsius to calculate temperature
    // Result is cast to int for "no decimal places" as per instructions
    cels = static_cast<int>(calcCelsius(fahr));

    // 3. Display the Celsius temperature
    cout << "Celsius temperature: " << cels << endl;

    return 0;
}

// getFahrenheit function: Enters and returns the Fahrenheit temperature
double getFahrenheit() {
    double temp;
    cout << "Enter the Fahrenheit temperature: ";
    cin >> temp;
    return temp;
}

// calcCelsius function: Calculates and returns the Celsius temperature
// Uses Pass by Value as noted in the "Observations" section
double calcCelsius(double fahrenheit) {
    return 5.0 / 9.0 * (fahrenheit - 32.0);
}

