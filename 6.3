#include <iostream>
using namespace std;

int main()
{
    int value;      // number of integers (n)
    int total = 0;  // sum of first n integers
    int number;
    float mean;     // average

    cout << "Please enter a positive integer: ";
    cin >> value;

    if (value > 0)
    {
        for (number = 1; number <= value; number++)
        {
            total = total + number;
        }

        mean = static_cast<float>(total) / value;

        cout << "The mean average of the first "
             << value << " positive integers is "
             << mean << endl;
    }
    else
    {
        cout << "Invalid input - integer must be positive" << endl;
    }

    return 0;
}
