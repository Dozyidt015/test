#include <iostream>
using namespace std;

int main()
{
	
	int month = 1;
	float total = 0, steps;

	cout << "Enter the total step for month: " << month << endl;
	cout << "Enter -1 when you are finished" << endl;
	cin >> steps;

	while (steps != -1)
	{
		total += steps;
		cout << "Enter the total steps for month " << month << endl;
		cout << "Enter -1 when you are finished" << endl;
		cin >> steps;
		month++;
	} 
	
	if(month == 1)
		cout << "No data has been entered." << endl;
	else
		cout << "The steps for " << month - 1 << " months is " << total << " steps." << endl;

	return 0;
}
