double getFahrenhiet() {
	double temp;
	cout << "Enter Fahrenhiet Temperature: "; cin >> temp;
	return temp;
	
}

double calcCelsius(double fahrenheit) {
	return 5.0 / 9.0 * (fahrenheit - 32.0);

}
