#include <iomanip>
using namespace std;

double getFahrenhiet();
double calcCelsius(double Fahrenhiet);

int main() {
	double fahr, cels;

	fahr = getFahrenhiet();
	cels = calcCelsius(fahr);

	cout << fixed << setprecision(0);
	cout << "Celsius Temperature: " << cels << endl;
	return 0;
